# =========================================================
# Unreal Engine + Windows + Visual Studio .gitignore
# Clean, production-ready defaults
# =========================================================

# ---------- Unreal generated folders ----------
Binaries/
Build/*/FileOpenOrder/
DerivedDataCache/
Intermediate/
Saved/

# Plugin generated content
Plugins/*/Binaries/
Plugins/*/Intermediate/

# ---------- Visual Studio ----------
.vs/
*.VC.db
*.VC.opendb
*.sdf
*.suo
*.opensdf
*.user
*.userprefs
*.VC.VC.opendb

# Rider / JetBrains
.idea/
*.sln.iml

# VS Code
.vscode/

# ---------- Build outputs ----------
*.obj
*.o
*.lib
*.dll
*.exe
*.pdb
*.exp
*.idb
*.ilk
*.app
*.ipa

# ---------- Logs / temp ----------
*.log
*.tmp
*.cache

# ---------- OS junk ----------
Thumbs.db
Desktop.ini
.DS_Store

# ---------- Python / misc tools ----------
__pycache__/
*.pyc

# ---------- Keep important UE files ----------
!*.uproject
!*.uplugin

